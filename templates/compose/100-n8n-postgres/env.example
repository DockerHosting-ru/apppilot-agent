# n8n with PostgreSQL Environment Variables
APP_ID=my-n8n-app
TEMPLATE_ID=100
EXTERNAL_PORT=8001
SERVER_IP=localhost
STACK_NAME=n8n-postgres-stack

# PostgreSQL Configuration
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password

# n8n Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_WEBHOOK_URL=http://localhost:8001
