# Nextcloud with PostgreSQL Environment Variables
APP_ID=my-nextcloud-app
TEMPLATE_ID=102
EXTERNAL_PORT=8003
SERVER_IP=localhost
STACK_NAME=nextcloud-postgres-stack

# PostgreSQL Configuration
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=nextcloud_password

# Nextcloud Configuration
NEXTCLOUD_TRUSTED_DOMAINS=localhost
NEXTCLOUD_UPDATE_CHECKER=0
NEXTCLOUD_CHECK_INSTALLER=0
NEXTCLOUD_APPS_INSTALL=1
NEXTCLOUD_APPS_ENABLE=1
