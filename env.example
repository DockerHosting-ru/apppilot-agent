# AppPilot Agent Environment Variables

# URL сервера AppPilot API
API_SERVER_URL=http://31.169.124.43:8000

# Уникальный идентификатор агента
AGENT_ID=test-agent-001

# JWT токен для аутентификации
JWT_TOKEN=your_jwt_token_here

# Интервал опроса сервера (в секундах)
POLL_INTERVAL=5

# Диапазон портов для приложений
PORT_RANGE_START=8001
PORT_RANGE_END=9000

# Путь к логам
LOG_PATH=/opt/appliku/logs

# Путь к приложениям
APPS_PATH=/opt/appliku/apps
